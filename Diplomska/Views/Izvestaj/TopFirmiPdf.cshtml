@model FirmaIzvestajViewModel
@{
    Layout = null;
}

<h3>Извештај</h3>
<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <style>
        body {
            font-family: Arial;
            font-size: 12px;
        }

        table {
            width: 100%;
            border-collapse: collapse;
        }

        th, td {
            border: 1px solid #000;
            padding: 6px;
        }

        th {
            background-color: #f2f2f2;
        }

        h2 {
            text-align: center;
        }
    </style>
</head>
<body>

    <h2>Топ 5 фирми – @Model.Period – @Model.SelectedYear</h2>

    <table>
        <thead>
            <tr>
                <th>Фирма</th>
                <th>Број на фактури</th>
                <th>Вкупен износ (ден.)</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var f in Model.TopFirmi)
            {
                <tr>
                    <td>@f.FirmaName</td>
                    <td>@f.BrojFakturi</td>
                    <td>@f.VkupenIznos.ToString("N2")</td>
                </tr>
            }
        </tbody>
    </table>

</body>
</html>

