@model List<FirmaGodiniViewModel>
@{
    Layout=null;
}
<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Извештај за фирма по години</title>
    <style>
        body {
            font-family: Arial, sans-serif;
            font-size: 12px;
        }

        table {
            border-collapse: collapse;
            width: 100%;
            margin-top: 20px;
        }

        th, td {
            border: 1px solid #000;
            padding: 8px;
            text-align: center;
        }

        th {
            background-color: #c20808;
            color: white;
        }

        h2 {
            text-align: center;
            margin-top: 20px;
        }
    </style>
</head>
<body>
    <h2>Извештај за фирма – Вкупен износ и број на фактури по години</h2>

    <table>
        <thead>
            <tr>
                <th>Година</th>
                <th>Број на фактури</th>
                <th>Вкупен износ</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.Godina</td>
                    <td>@item.BrojFakturi</td>
                    <td>@item.VkupenIznos.ToString("N2")</td>
                </tr>
            }
        </tbody>
    </table>
</body>
</html>

