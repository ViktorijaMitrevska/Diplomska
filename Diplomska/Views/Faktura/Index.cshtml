@model PagedResultViewModel<VleznaFaktura>

@{
    ViewData["Title"] = "Фактури";
}
<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css" rel="stylesheet">

<style>
    .plateno-checkbox:checked {
        background-color: #c20808;
        border-color: #c20808;
    }
    
    .plateno-checkbox:focus {
        border-color: #c20808;
        box-shadow: 0 0 0 0.25rem rgba(194, 8, 8, 0.25);
    }
    
    .plateno-checkbox {
        cursor: pointer;
    }

        .faktura-checkbox:checked {
            background-color: #c20808;
            border-color: #c20808;
        }

        .faktura-checkbox:focus {
            border-color: #c20808;
            box-shadow: 0 0 0 0.25rem rgba(194, 8, 8, 0.25);
        }

    .faktura-checkbox {
        cursor: pointer;
    }

    .dodaj{
        background-color: #c20808;
        border-color: #c20808;
        height:35px;
 

    }
    .dodaj:hover{
        background-color:white;
        color: #c20808;
        border-color: #c20808;
    }
    .kopcinja{
        display:flex;
        flex-direction: row;
    }
    .kopcinja a{
        margin: 5px;
    }

    .pagination .page-item.active .page-link {
        background-color: #c20808;
        border-color: #c20808;
        color: white;
    }

    .pagination .page-link:hover {
        background-color: #f2f2f2;
        color: #000;
    }

    .pagination .page-link {
        color: #c20808;
    }
</style>

<h2>Листа на фактури</h2>
<div class="container px-0">
    
    <div class="d-flex justify-content-between">
        <div class="kopcinja">
            <a class="btn btn-primary dodaj mt-2" asp-action="Create"> <i class="bi bi-plus-circle" style="margin-right:5px;margin-top:25px;"></i>Додај</a>

            <form method="get" asp-action="Index" class="d-flex align-items-center gap-2">
                <select name="godina" class="form-select" style="width:200px;">
                    @for (int y = DateTime.Now.Year; y >= 2024; y--)
                    {
                        <option value="@y" selected="@(ViewBag.SelectedYear == y)">
                            @y година
                        </option>
                    }
                </select>

                <button type="submit" class="btn btn-primary "
                        style="background-color:#c20808; border-color:#c20808;">
                    Прикажи
                </button>
            </form>
        </div>


        <a asp-action="Saldo" class="btn btn-warning" style="margin:10px;">
            Салдо од претходни години: @ViewBag.Saldo.ToString("N2") ден
        </a>
    </div>
    
</div>



<div class="container px-0">

<form method="get" asp-action="@(ViewContext.RouteData.Values["action"]?.ToString())">
        <input type="hidden" name="godina" value="@ViewBag.SelectedYear" />
    <div class="row g-2 mb-4 align-items-center">
        <div class="col-md-4">
            <input type="text" name="searchString" class="form-control" placeholder="Барај фактура..." />
        </div>
        <div class="col-md-4">
           
            <select name="firmaId" class="form-select">
                <option value="">-- Сите фирми --</option>

                    @foreach (var firma in ViewBag.FirmiList as List<Firma>)
                    {
                        <option value="@firma.FirmaId"
                                selected="@(firma.FirmaId == Context.Request.Query["firmaId"])">
                            @firma.Name
                        </option>
                    }

            </select>
        </div>

       
        <div class="col-md-4">
            <button type="submit" class="btn btn-primary w-100" style="background-color:#c20808; border-color: #c20808;">
                <i class="bi bi-search"></i> Пребарај
            </button>
        </div>
    </div>
</form>

<div class="kopcinja">
    <a class="btn btn-primary dodaj" asp-action="Index">
        <i class="bi bi-receipt"></i>
        Сите
    </a>
        <a class="btn btn-primary dodaj"
           asp-action="Neplateni"
           asp-route-godina="@ViewBag.SelectedYear"
           asp-route-firmaId="@ViewBag.SelectedFirmaId"
           asp-route-searchString="@Context.Request.Query["searchString"]">
            <i class="bi bi-terminal-x"></i>
            Неплатени
        </a>

</div>

<div class="alert alert-secondary mt-3">
    Вкупно селектирано:
    <strong id="vkupnoSuma">0.00</strong> ден
</div>

@if (!Model.Items.Any()||Model==null)
{
    <div class="alert alert-info">
        Не е пронајдена ниту една фактура.
    </div>
}
else
{   
    <table class="table table-hover">
        <thead>
            <tr>
                <th scope="col"></th>
                <th scope="col">Маркет</th>
                <th scope="col">Број на фактура</th>
                <th scope="col">Име на фирма</th>
                <th scope="col" class="text-end">Износ</th>
                <th scope="col" class="text-center">Платено</th>
                <th scope ="col">Дата на плаќање</th>
                <th scope="col"></th>
            </tr>
        </thead>
        <tbody>
        @foreach (var faktura in Model.Items)
        {
           
                <tr>
                    <td class="text-center">
                        <input type="checkbox"
                               class="form-check-input faktura-checkbox"
                               data-suma="@faktura.Suma"
                               data-id="@faktura.FakturaId" />
                    </td>
                    <th scope="row">@faktura.Market</th>
                    <td>@faktura.BrojNaDokument</td>
                    <td>@(faktura.Firma?.Name ?? "N/A")</td>
                    <td class="text-end">
                        @faktura.Suma.ToString("N2") ден
                    </td>
                    <td class="text-center">
                        <div class="form-check d-flex justify-content-center">
                            <input type="checkbox" 
                                   class="form-check-input plateno-checkbox" 
                                   data-faktura-id="@faktura.FakturaId"
                                   @(faktura.DaliEPlateno ? "checked" : "")
                                       onchange="openConfirmModal(this)" />
                        </div>
                    </td>
                    <td>
                        @(faktura.PaymentDate?.ToString("dd.MM.yyyy") ?? "-")
                    </td>
                    <td>
                        <a asp-action="Edit" asp-route-id="@faktura.FakturaId" class="btn btn-primary" style="background-color:#c20808; border-color: #c20808;">Уреди</a>
                    </td>
                </tr>
            
        } 
        </tbody> 
    </table>
        @if (Model.TotalPages > 1)
        {
            <nav>
                <ul class="pagination justify-content-center">

                    <li class="page-item @(Model.Page == 1 ? "disabled" : "")">
                        <a class="page-link"
                           asp-action="Index"
                           asp-route-page="@(Model.Page - 1)">
                            ←
                        </a>
                    </li>

                    @for (int i = 1; i <= Model.TotalPages; i++)
                    {
                        <li class="page-item @(i == Model.Page ? "active" : "")">
                            <a class="page-link"
                               asp-action="Index"
                               asp-route-page="@i">
                                @i
                            </a>
                        </li>
                    }

                    <li class="page-item @(Model.Page == Model.TotalPages ? "disabled" : "")">
                        <a class="page-link"
                           asp-action="Index"
                           asp-route-page="@(Model.Page + 1)">
                            →
                        </a>
                    </li>

                </ul>
            </nav>
        }

    }
</div>
<!-- Confirm Modal -->
<div class="modal fade" id="confirmPlatenoModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Потврда</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body">
                <p id="confirmMessage"></p>
            </div>

            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
                    Откажи
                </button>
                <button type="button" class="btn btn-danger" id="confirmYesBtn">
                    Потврди
                </button>
            </div>
        </div>
    </div>
</div>
<!-- Toast container -->
<div class="toast-container position-fixed bottom-0 end-0 p-3">

    <div id="appToast" class="toast align-items-center text-white border-0"
         role="alert" aria-live="assertive" aria-atomic="true">

        <div class="d-flex">
            <div class="toast-body" id="toastMessage">
                Порака
            </div>
            <button type="button" class="btn-close btn-close-white me-2 m-auto"
                    data-bs-dismiss="toast"></button>
        </div>
    </div>

</div>

@section Scripts {
    <script>
        let pendingCheckbox = null;
        let originalState = false;

        function openConfirmModal(checkbox) {
            pendingCheckbox = checkbox;
            originalState = !checkbox.checked;

            const isChecked = checkbox.checked;

            const message = isChecked
                ? "Дали сте сигурни дека сакате да ја означите фактурата како ПЛАТЕНА?"
                : "Дали сте сигурни дека сакате да ја тргнете ознаката ПЛАТЕНА?";

            document.getElementById("confirmMessage").innerText = message;

            const modal = new bootstrap.Modal(
                document.getElementById("confirmPlatenoModal")
            );
            modal.show();
        }

        document.getElementById("confirmYesBtn").addEventListener("click", function () {
            if (!pendingCheckbox) return;

            const fakturaId = pendingCheckbox.getAttribute("data-faktura-id");
            const isChecked = pendingCheckbox.checked;

            fetch('@Url.Action("UpdatePlateno", "Faktura")', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/x-www-form-urlencoded',
                    'Accept': 'application/json'
                },
                body: `fakturaId=${encodeURIComponent(fakturaId)}&daliEPlateno=${isChecked}`
            })
            .then(r => r.json())
                    .then(data => {
            if (!data.success) {
                throw new Error(data.error || "Грешка");
            }

            showToast(
                pendingCheckbox.checked
                    ? "Фактурата е означена како платена"
                    : "Ознаката за платено е тргната",
                "success"
            );
        })

            .catch(err => {
                showToast("Грешка при ажурирање: " + err.message, "error");

                pendingCheckbox.checked = originalState;
            })
            .finally(() => {
                pendingCheckbox = null;
                bootstrap.Modal.getInstance(
                    document.getElementById("confirmPlatenoModal")
                ).hide();
            });
        });

        document.getElementById("confirmPlatenoModal")
            .addEventListener("hidden.bs.modal", function () {
                if (pendingCheckbox) {
                    pendingCheckbox.checked = originalState;
                    pendingCheckbox = null;
                }
            });
    </script>

    <script>
        function showToast(message, type = "success") {
            const toastEl = document.getElementById("appToast");
            const toastMsg = document.getElementById("toastMessage");

            toastMsg.innerText = message;

            toastEl.classList.remove("bg-success", "bg-danger", "bg-warning");

            if (type === "success") toastEl.classList.add("bg-success");
            if (type === "error") toastEl.classList.add("bg-danger");
            if (type === "warning") toastEl.classList.add("bg-warning");

            const toast = new bootstrap.Toast(toastEl, { delay: 3000 });
            toast.show();
        }
    </script>


    <script>
        document.querySelectorAll('.faktura-checkbox').forEach(cb => {
            cb.addEventListener('change', presmetaj);
        });

        function presmetaj() {
            let total = 0;

            document.querySelectorAll('.faktura-checkbox:checked').forEach(cb => {
                total += parseFloat(cb.dataset.suma);
            });

            document.getElementById('vkupnoSuma').innerText =
                total.toLocaleString('mk-MK', { minimumFractionDigits: 2 });
        }
    </script>

}
