@model Diplomska.ViewModels.Auth.ForgotPasswordViewModel;

@{
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Заборавена лозинка</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
</head>

<body class="bg-light d-flex align-items-center justify-content-center vh-100">

    <div class="card shadow overflow-hidden" style="max-width: 900px; width: 100%;">
        <div class="row g-0" style="min-height: 450px;">

            <!-- ЛЕВА СТРАНА – IMAGE -->
            <div class="col-md-6 d-none d-md-block">
                <img src="~/images/forgotPassword.jpg"
                     class="w-100 h-100"
                     style="object-fit: cover;"
                     alt="Forgot password" />
            </div>

            <!-- ДЕСНА СТРАНА – FORM -->
            <div class="col-md-6 d-flex align-items-center">
                <div class="p-4 w-100">

                    <h4 class="text-center mb-2">Заборавена лозинка</h4>
                    <p class="text-muted text-center mb-4">
                        Внесете ја вашата e-mail адреса и ќе добиете инструкции.
                    </p>

                    <form asp-action="ForgotPassword" method="post">

                        <div class="mb-3">
                            <label class="form-label">E-адреса</label>
                            <input asp-for="Email" class="form-control" />
                            <span asp-validation-for="Email" class="text-danger"></span>
                        </div>

                        <button class="btn btn-primary w-100 mb-3" style="background-color:#c20808; border-color: #c20808;">
                            Испрати линк
                        </button>

                        <div class="text-center" >
                            <a asp-action="Login" style="color:black;">Назад кон најава</a>
                        </div>

                        @if (ViewBag.Success != null)
                        {
                            <div class="alert alert-success mt-3 text-center">
                                @ViewBag.Success
                            </div>
                        }

                        @if (!ViewData.ModelState.IsValid)
                        {
                            <div class="text-danger mt-3">
                                @Html.ValidationSummary()
                            </div>
                        }
                    </form>

                </div>
            </div>

        </div>
    </div>

</body>
</html>