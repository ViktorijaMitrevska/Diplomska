@model Diplomska.ViewModels.Auth.RegisterViewModel
@{
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Регистрација</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
</head>
<body class="bg-light d-flex align-items-center justify-content-center vh-100">

    <div class="card shadow" style="max-width: 800px; width: 100%;">
        <div class="row g-0">
            <div class="col-md-6 d-none d-md-flex align-items-center justify-content-center bg-light">
                <img src="~/images/login.jpg"
                     class="img-fluid p-1"
                     style="height:100%;"
                     alt="Login image" />
            </div>
            <div class="col-md-6 p-4">
                <h4 class="text-center mb-4">Регистрација</h4>

                <form asp-action="RegisterEmployee" method="post">
                    <div class="mb-3">
                        <label class="form-label">Име</label>
                        <input asp-for="Name" class="form-control" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Е-адреса</label>
                        <input asp-for="Email" class="form-control" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Лозинка</label>
                        <input asp-for="Password" type="password" class="form-control" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Потврди Лозинка</label>
                        <input asp-for="ConfirmPassword" type="password" class="form-control" />
                    </div>

                    <button class="btn btn-primary w-100" style="background-color:#c20808; border-color: #c20808;">Регистрирај вработен</button>
                    <div class="card-footer text-center">
                        <a  asp-action="Profile">
                            Назад
                        </a>
                    </div>

                    @if (!ViewData.ModelState.IsValid)
                    {
                        <div class="text-danger mt-3">
                            @Html.ValidationSummary()
                        </div>
                    }
                </form>
            </div>
        </div>

    </div>

</body>
</html>

