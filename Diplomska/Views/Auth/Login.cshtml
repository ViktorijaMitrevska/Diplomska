@model Diplomska.ViewModels.Auth.LoginViewModel
@{
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Најава</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
</head>
<body class="bg-light d-flex align-items-center justify-content-center vh-100">

    <div class="card shadow" style="max-width: 800px; width: 100%;">
        <div class="row g-0">

            <div class="col-md-6 d-none d-md-flex align-items-center justify-content-center bg-light">
                <img src="~/images/login.jpg"
                     class="img-fluid p-1"
                     alt="Login image" />
            </div>

            <div class="col-md-6 p-4">

                <h4 class="text-center mb-4">Најава</h4>

                <form asp-action="Login" method="post">

                    <div class="mb-3">
                        <label class="form-label">Е-адреса</label>
                        <input asp-for="Email" class="form-control" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Лозинка</label>
                        <input asp-for="Password" type="password" class="form-control" />
                    </div>

                    <button class="btn btn-primary w-100 mb-2" style="background-color:#c20808; border-color: #c20808;">
                        Најави се
                    </button>

                    <div class="d-flex justify-content-between" style="color:black;">
                        @if (!(ViewBag.OwnerExists as bool? ?? false))
                        {
                            <a asp-action="RegisterOwner" style="color:black;">Регистрација</a>
                        }

                        
                        <a asp-action="ForgotPassword" style="color:black;">Заборавена лозинка?</a>
                    </div>

                    @if (!ViewData.ModelState.IsValid)
                    {
                        <div class="text-danger mt-3">
                            @Html.ValidationSummary()
                        </div>
                    }
                </form>
            </div>
        </div>
    </div>

    <div class="toast-container position-fixed bottom-0 end-0 p-3">

        @if (ViewBag.Reason == "logout")
        {
            <div class="toast align-items-center text-bg-info border-0 show" role="alert">
                <div class="d-flex">
                    <div class="toast-body">
                        <i class="bi bi-check-circle"></i>Успешно се одјавивте.
                    </div>
                    <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"></button>
                </div>
            </div>
        }

        @if (ViewBag.Reason == "expired")
        {
            <div class="toast align-items-center text-bg-warning border-0 show" role="alert">
                <div class="d-flex">
                    <div class="toast-body">
                        <i class="bi bi-hourglass-split"></i> Вашата сесија истече. Ве молиме најавете се повторно.
                    </div>
                    <button type="button" class="btn-close me-2 m-auto" data-bs-dismiss="toast"></button>
                </div>
            </div>
        }

    </div>

</body>


</html>
<script>
    document.querySelectorAll('.toast').forEach(toastEl => {
        const toast = new bootstrap.Toast(toastEl, {
            delay: 4000
        });
        toast.show();
    });
</script>
