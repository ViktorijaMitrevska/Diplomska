<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Diplomska</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Diplomska.styles.css" asp-append-version="true" />
    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css">

</head>
<body>
   
    <div class="d-flex">
        @if (User.Identity != null && User.Identity.IsAuthenticated)
        {
            <nav class="sidebar d-flex flex-column">
                <div class="sidebar-header">
                    <a class="navbar-brand" asp-area="" asp-controller="Firma" asp-action="Index"><img src="~/uploads/Б.png" height="75" width="170" /></a>
                </div>

                <ul class="nav flex-column">
                    <li class="nav-item">
                        <a class="nav-link " asp-controller="Firma" asp-action="Index">
                            <i class="bi bi-building"></i> Фирми
                        </a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Faktura" asp-action="Index">
                            <i class="bi bi-receipt"></i> Фактури
                        </a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Kartica" asp-action="Index">
                            <i class="bi bi-card-list"></i> Картица
                        </a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Izvestaj" asp-action="TopFirmi">
                            <i class="bi bi-bar-chart-line"></i> Извештај
                        </a>
                        
                    </li>
                    
                    <li class="nav-item">
                        @await Component.InvokeAsync("NotificationBadge")
                    </li>
                    </ul>
                <ul class="nav flex-column mt-auto">
                    <li class="nav-item">
                        <a asp-controller="Auth" asp-action="Profile" class="nav-link">
                            <i class="bi bi-person"></i> Профил
                        </a>
                    </li>
                    <li class="nav-item">
                        <a asp-controller="Auth" asp-action="Logout" class="nav-link">
                            Одјави се
                        </a>
                    </li>


                </ul>
            </nav>
        }
        
        <main class="content">
            @RenderBody()
        </main>

    </div> 


    <footer class="footer text-muted">
        @* <div class="container" style="align-items:center; justify-items:center;">
            &copy; 2025 - Diplomska 
        </div> *@
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
