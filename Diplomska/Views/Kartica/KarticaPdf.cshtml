@model MakeNewKarticaViewModel
@{
    Layout = null; 
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <style>
        body {
            font-family: DejaVu Sans, Arial, sans-serif;
            font-size: 12px;
        }

        table {
            width: 100%;
            border-collapse: collapse;
        }

        th, td {
            border: 1px solid #000;
            padding: 4px;
        }

        th {
            background-color: #eee;
        }

        .text-end {
            text-align: right;
        }
    </style>
</head>
<body>

    <h3>Картица на добавувач</h3>

    <p>
        <strong>Фирма:</strong> @Model.Firma?.Name <br />
        <strong>Период:</strong>
        @Model.Od?.ToString("dd.MM.yyyy")
        -
        @Model.Do?.ToString("dd.MM.yyyy")
    </p>

    <table>
        <thead>
            <tr>
                <th>Датум</th>
                <th>Опис</th>
                <th class="text-end">Должи</th>
                <th class="text-end">Платено</th>
                <th class="text-end">Салдо</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var s in Model.Stavki)
            {
                <tr>
                    <td>@s.Datum.ToString("dd.MM.yyyy")</td>
                    <td>@s.Opis</td>
                    <td class="text-end">
                        @(s.Dolzi > 0 ? s.Dolzi.ToString("N2") : "-")
                    </td>
                    <td class="text-end">
                        @(s.Plateno > 0 ? s.Plateno.ToString("N2") : "-")
                    </td>
                    <td class="text-end">@s.Saldo.ToString("N2")</td>
                </tr>
            }
        </tbody>
        <tfoot>
            <tr>
                <th colspan="2" class="text-end">ВКУПНО</th>
                <th class="text-end">@Model.VkupnoDolzi.ToString("N2")</th>
                <th class="text-end">@Model.VkupnoPlateno.ToString("N2")</th>
                <th class="text-end">@Model.Saldo.ToString("N2")</th>
            </tr>
        </tfoot>
    </table>

</body>
</html>
