@model Diplomska.ViewModels.MakeNewKarticaViewModel

<form asp-action="Index" asp-controller="Kartica" method="get">
    <div class="row mb-4">

        <div class="col-md-3">
            <label>Од</label>
            <input asp-for="Od" type="date" class="form-control" />
        </div>

        <div class="col-md-3">
            <label>До</label>
            <input asp-for="Do" type="date" class="form-control" />
        </div>

        <div class="col-md-4">
            <label>Фирма</label>
            <select asp-for="FirmaId" class="form-select">
                <option value="">-- Избери фирма --</option>
                @foreach (var f in Model.Firmi ?? new())
                {
                    <option value="@f.FirmaId">@f.Name</option>
                }
            </select>
        </div>

        <div class="col-md-2 d-flex align-items-end">
            <button type="submit" class="btn btn-primary w-100" style="background-color:#c20808; border-color: #c20808;">
                Пребарај
            </button>
        </div>

    </div>
</form>

@if (Model.Stavki != null && Model.Stavki.Any())
{
    <table class="table table-bordered table-sm mt-4">
        <thead class="table-light">
            <tr>
                <th style="width:120px;">Датум</th>
                <th>Опис</th>
                <th class="text-end">Должи</th>
                <th class="text-end">Платено</th>
                <th class="text-end">Салдо</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var s in Model.Stavki)
            {
                <tr>
                    <td>@s.Datum.ToString("dd.MM.yyyy")</td>
                    <td>@s.Opis</td>

                    <td class="text-end">
                        @(s.Dolzi > 0 ? s.Dolzi.ToString("N2") : "-")
                    </td>

                    <td class="text-end">
                        @(s.Plateno > 0 ? s.Plateno.ToString("N2") : "-")
                    </td>

                    <td class="text-end fw-bold">
                        @s.Saldo.ToString("N2")
                    </td>
                </tr>
            }
        </tbody>

        <tfoot class="table-secondary fw-bold">
            <tr>
                <td colspan="2" class="text-end">ВКУПНО ПЕРИОД:</td>
                <td class="text-end">@Model.PeriodDolzi.ToString("N2")</td>
                <td class="text-end">@Model.PeriodPlateno.ToString("N2")</td>
                <td class="text-end">@Model.SaldoPeriod.ToString("N2")</td>
            </tr>
            <tr>
                <td colspan="2" class="text-end">ВКУПНО:</td>
                <td class="text-end">@Model.VkupnoDolzi.ToString("N2")</td>
                <td class="text-end">@Model.VkupnoPlateno.ToString("N2")</td>
                <td class="text-end">@Model.Saldo.ToString("N2")</td>
            </tr>
        </tfoot>
    </table>
}
else
{
    <div class="alert alert-info mt-4">
        Нема податоци за избраниот период.
    </div>
}

@if (Model.Stavki != null && Model.Stavki.Any())
{
    <a class="btn btn-danger"
       asp-action="KarticaPdf"
       asp-controller="Kartica"
       asp-route-firmaId="@Model.FirmaId"
       asp-route-od="@Model.Od"
       asp-route-do="@Model.Do">
        Генерирај PDF
    </a>
    <a asp-action="KarticaExcel"
       asp-route-firmaId="@Model.FirmaId"
       asp-route-od="@Model.Od"
       asp-route-doD="@Model.Do"
       class="btn btn-success ms-2">
        <i class="bi bi-file-earmark-excel"></i> Export Excel
    </a>

}
